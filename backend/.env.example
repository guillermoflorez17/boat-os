# =========================
# Boat OS data source
# =========================
BOAT_OS_DATA_SOURCE=simulator
SIGNAL_K_URL=http://localhost:3000

# =========================
# AIS thresholds
# =========================
AIS_GUARD_ZONE_NM=1.5
AIS_CRITICAL_DISTANCE_NM=0.5

AIS_CPA_CRITICAL_NM=0.25
AIS_TCPA_CRITICAL_MIN=15

AIS_CPA_WARNING_NM=0.75
AIS_TCPA_WARNING_MIN=30

# =========================
# Energy thresholds
# =========================
BATTERY_CRITICAL_PERCENT=20
BATTERY_WARNING_PERCENT=40

# =========================
# Raspberry thresholds
# =========================
RASPBERRY_TEMP_CRITICAL=70
RASPBERRY_TEMP_WARNING=60

# =========================
# OpenCPN
# =========================
OPENCPN_ENABLED=false
OPENCPN_COMMAND=opencpn

# =========================
# System monitor
# =========================
SYSTEM_MONITOR_ENABLED=true

# =========================
# Simulator
# =========================
SIMULATION_DYNAMIC_ENABLED=true
SIMULATION_TIME_SCALE=20
SIMULATION_LOOP_MINUTES=20
SIMULATION_DEFAULT_SCENARIO=normal

# =========================
# Runtime mode
# =========================
BOAT_OS_MODE=development